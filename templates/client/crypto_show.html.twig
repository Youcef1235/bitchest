{% extends 'base_app.html.twig' %}
{% block title %}{{ crypto.name }} - BitChest{% endblock %}

{% block nav %}
    <a href="{{ path('client_dashboard') }}">Dashboard</a>
    <a href="{{ path('client_cryptos') }}" class="active">Cryptos</a>
    <a href="{{ path('client_profile') }}">Profile</a>
{% endblock %}

{% block content %}
<div class="d-flex align-items-center gap-3 mb-4">
    <div class="crypto-icon" style="background:#F7931A; width:48px; height:48px; font-size:1.1rem;">{{ crypto.symbol[0] }}</div>
    <div>
        <h2 class="mb-0">{{ crypto.name }}</h2>
        <span style="color:#fff; opacity:0.8;">{{ crypto.symbol }}</span>
    </div>
    <div class="ms-auto" style="font-size:1.5rem; font-weight:bold; color:#fff;">
        € {{ currentPrice|number_format(2, '.', ',') }}
    </div>
</div>

<div class="row g-3">
    <div class="col-md-8">
        <div class="bc-card">
            <div style="height:280px;">
                <canvas id="priceChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="bc-card">
            <h6 class="mb-3">Buy {{ crypto.symbol }}</h6>
            <form method="post" action="{{ path('client_buy', {id: crypto.id}) }}">
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.9rem;">Quantity</label>
                    <input type="number" name="quantity" class="bc-input" step="0.00000001" min="0.00000001" placeholder="e.g. 0.5" required>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.9rem;">Price</label>
                    <input type="text" class="bc-input" value="€ {{ currentPrice|number_format(2, '.', ',') }}" readonly>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:0.9rem;">Your Balance</label>
                    <input type="text" class="bc-input" value="€ {{ app.user.balance|number_format(2, '.', ',') }}" readonly>
                </div>
                <button type="submit" class="btn-green-full">Buy Now</button>
            </form>
        </div>
    </div>
</div>
<a href="{{ path('client_cryptos') }}" style="color:#fff; display:inline-block; margin-top:1rem;">← Back</a>
{% endblock %}

{% block javascripts %}
<script>
new Chart(document.getElementById('priceChart').getContext('2d'), {
    type: 'line',
    data: {
        labels: {{ labels|json_encode|raw }},
        datasets: [{
            label: '{{ crypto.symbol }} (€)',
            data: {{ prices|json_encode|raw }},
            borderColor: '#FF5964',
            backgroundColor: 'rgba(255,89,100,0.08)',
            borderWidth: 2,
            fill: true,
            tension: 0.3,
            pointRadius: 2,
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { y: { ticks: { callback: v => '€' + v.toLocaleString() } } }
    }
});
</script>
{% endblock %}