{% extends 'base_app.html.twig' %}
{% block title %}Cryptocurrencies - BitChest{% endblock %}

{% block nav %}
    <a href="{{ path('client_dashboard') }}">Dashboard</a>
    <a href="{{ path('client_portfolio') }}">Portfolio</a>
    <a href="{{ path('client_cryptos') }}" class="active">Cryptos</a>
{% endblock %}

{% block content %}
<h2 class="mb-4">Cryptocurrencies</h2>
<div class="row g-3">
    {% for crypto in cryptos %}
    <div class="col-md-6 col-lg-4">
        <div class="bc-card">
            <div style="display:flex; align-items:center; gap:10px; margin-bottom:0.5rem;">
                <div class="crypto-icon" style="background:#F7931A;">{{ crypto.symbol|slice(0,1) }}</div>
                <div>
                    <div style="font-weight:bold;">{{ crypto.name }}</div>
                    <small style="color:#999;">{{ crypto.symbol }}</small>
                </div>
            </div>
            <div style="height:80px; margin: 0.5rem 0;">
                <canvas id="chart-{{ crypto.id }}"></canvas>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                <small>Current Price</small>
                <strong>€ {{ latestCotations[crypto.id]|number_format(2, '.', ',') }}</strong>
            </div>
            <form method="post" action="{{ path('client_buy', {id: crypto.id}) }}" style="display:flex; gap:8px;">
                <input type="number" name="quantity" class="bc-input" style="flex:1;" step="0.00000001" min="0.00000001" placeholder="Amount" required>
                <button type="submit" class="btn-green">Buy</button>
            </form>
        </div>
    </div>
    {% endfor %}
</div>
{% endblock %}

{% block javascripts %}
<script>
const chartData = {{ chartData|json_encode|raw }};
chartData.forEach(function(d) {
    const ctx = document.getElementById('chart-' + d.id);
    if (!ctx) return;
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: d.labels,
            datasets: [{
                data: d.prices,
                borderColor: '#FF5964',
                borderWidth: 1.5,
                fill: false,
                pointRadius: 0,
                tension: 0.3
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { x: { display: false }, y: { display: false } }
        }
    });
});
</script>
{% endblock %}