{% extends 'base_app.html.twig' %}
{% block title %}Profile - BitChest{% endblock %}

{% block sidebar %}
    <li><a href="{{ path('client_dashboard') }}" class="nav-link"><i class="bi bi-wallet2"></i> My Wallet</a></li>
    <li><a href="{{ path('client_cryptos') }}" class="nav-link"><i class="bi bi-currency-bitcoin"></i> Cryptocurrencies</a></li>
    <li><a href="{{ path('client_profile') }}" class="nav-link active"><i class="bi bi-person"></i> Profile</a></li>
{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-person"></i> My Profile</h5></div>
            <div class="card-body p-4">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">First Name</label>
                        <input type="text" name="firstname" class="form-control" value="{{ user.firstname }}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Last Name</label>
                        <input type="text" name="lastname" class="form-control" value="{{ user.lastname }}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" name="email" class="form-control" value="{{ user.email }}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Balance</label>
                        <input type="text" class="form-control" value="€ {{ user.balance|number_format(2, '.', ',') }}" readonly>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}