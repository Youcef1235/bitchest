{% extends 'base.html.twig' %}
{% block theme %}{% if is_granted('ROLE_ADMIN') %}theme-admin{% else %}theme-client{% endif %}{% endblock %}

{% block body %}
<nav class="bc-navbar">
    <a class="brand" href="#">BitChest</a>
    <div class="nav-links">
        {% block nav %}{% endblock %}
    </div>
    <div class="d-flex align-items-center gap-3">
        {% if is_granted('ROLE_USER') and not is_granted('ROLE_ADMIN') %}
            <span class="balance-badge">€ {{ app.user.balance|number_format(2, '.', ',') }}</span>
        {% endif %}
        <a href="{{ path('app_logout') }}" style="color:#fff; text-decoration:none; font-size:0.9rem;">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>
</nav>
<div class="bc-page">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show">
            {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show">
            {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% block content %}{% endblock %}
</div>
<footer class="bc-footer">© 2025 BitChest</footer>
{% endblock %}