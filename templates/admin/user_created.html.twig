{% extends 'base_app.html.twig' %}
{% block title %}User Created - BitChest{% endblock %}

{% block sidebar %}
    <li><a href="{{ path('admin_dashboard') }}" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
    <li><a href="{{ path('admin_users') }}" class="nav-link active"><i class="bi bi-people"></i> Users</a></li>
    <li><a href="{{ path('admin_cryptos') }}" class="nav-link"><i class="bi bi-currency-bitcoin"></i> Cryptocurrencies</a></li>
{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-check-circle"></i> User Created Successfully</h5></div>
            <div class="card-body p-4">
                <p>The user <strong>{{ user.firstname }} {{ user.lastname }}</strong> has been created.</p>
                <div class="alert alert-warning">
                    <strong><i class="bi bi-key"></i> Temporary Password:</strong>
                    <span class="fs-5 ms-2 font-monospace">{{ tempPassword }}</span>
                    <br><small>Please send this password to the user. It will not be shown again.</small>
                </div>
                <p><strong>Email:</strong> {{ user.email }}</p>
                <p><strong>Starting Balance:</strong> € 500.00</p>
                <a href="{{ path('admin_users') }}" class="btn btn-primary">Back to Users</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}