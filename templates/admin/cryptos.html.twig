{% extends 'base_app.html.twig' %}
{% block title %}Cryptocurrencies - BitChest{% endblock %}

{% block sidebar %}
    <li><a href="{{ path('admin_dashboard') }}" class="nav-link"><i class="bi bi-speedometer2"></i> Dashboard</a></li>
    <li><a href="{{ path('admin_users') }}" class="nav-link"><i class="bi bi-people"></i> Users</a></li>
    <li><a href="{{ path('admin_cryptos') }}" class="nav-link active"><i class="bi bi-currency-bitcoin"></i> Cryptocurrencies</a></li>
{% endblock %}

{% block content %}
<h2 class="mb-4">Cryptocurrencies</h2>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Symbol</th>
                    <th>Current Price</th>
                </tr>
            </thead>
            <tbody>
                {% for crypto in cryptos %}
                <tr>
                    <td><strong>{{ crypto.name }}</strong></td>
                    <td><span class="badge bg-secondary">{{ crypto.symbol }}</span></td>
                    <td>€ {{ latestCotations[crypto.id]|number_format(2, '.', ',') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}