{
    "name": "bitchest/bitchest",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^8.0",
        "symfony/runtime": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0",
        "twig/twig": "^3.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/security-bundle": "^8.0",
        "symfony/orm-pack": "^2.0",
        "symfony/form": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/password-hasher": "^8.0",
        "doctrine/doctrine-fixtures-bundle": "^4.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "symfony/maker-bundle": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    }
}
